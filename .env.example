# Datenschleuse Configuration

# FileBrowser Admin User
FB_ADMIN_USER=admin
FB_ADMIN_PASSWORD=changeme

# Cloudflare Tunnel
CF_TUNNEL_NAME=datenschleuse
CF_TUNNEL_URL=datenschleuse.yourdomain.com

# ClamAV
CLAMAV_MAX_FILESIZE=500M
SCAN_INTERVAL=3600

# Security
MAX_FILE_SIZE=10G
LOG_RETENTION_DAYS=30
